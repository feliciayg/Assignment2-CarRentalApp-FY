<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sr_background"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarMain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/sr_header_bg"
        android:elevation="0dp"
        app:liftOnScroll="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/sr_header_bg"
            android:orientation="vertical"
            android:paddingStart="@dimen/header_padding_horizontal"
            android:paddingTop="@dimen/header_padding_top_large"
            android:paddingEnd="@dimen/header_padding_horizontal"
            android:paddingBottom="@dimen/header_padding_bottom_large">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <com.google.android.material.appbar.MaterialToolbar
                        android:id="@+id/toolbarMain"
                        style="@style/Widget.SwiftRent.HeaderToolbar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:title="@string/app_name"
                        app:titleCentered="false" />

                    <LinearLayout
                        android:id="@+id/layoutHeaderControls"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/header_chip_margin_top"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardBalanceChip"
                            style="@style/Widget.SwiftRent.HeaderChipCard"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/header_chip_margin_start">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="@dimen/header_chip_horizontal_padding"
                                android:paddingTop="@dimen/header_chip_vertical_padding"
                                android:paddingEnd="@dimen/header_chip_horizontal_padding"
                                android:paddingBottom="@dimen/header_chip_vertical_padding">

                                <ImageView
                                    android:id="@+id/imageBalanceChip"
                                    android:layout_width="13dp"
                                    android:layout_height="@dimen/header_chip_icon_size"
                                    android:contentDescription="@string/sample_balance_chip"
                                    android:src="@drawable/ic_wallet_simple"
                                    app:tint="@color/sr_header_chip_text" />

                                <TextView
                                    android:id="@+id/textBalanceChip"
                                    style="@style/TextAppearance.SwiftRent.HeaderChip"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/space_sm"
                                    android:text="@string/sample_balance_chip" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/theme_toggle_section_margin_end"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardThemeToggle"
                        style="@style/Widget.SwiftRent.ThemeToggleCard"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <FrameLayout
                            android:layout_width="@dimen/theme_toggle_outer_width"
                            android:layout_height="@dimen/theme_toggle_outer_height"
                            android:paddingStart="@dimen/theme_toggle_frame_padding"
                            android:paddingTop="@dimen/theme_toggle_frame_padding"
                            android:paddingEnd="@dimen/theme_toggle_frame_padding"
                            android:paddingBottom="@dimen/theme_toggle_frame_padding">

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switchDarkMode"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:checked="false"
                                android:minWidth="0dp"
                                android:minHeight="0dp"
                                android:padding="0dp"
                                android:showText="false"
                                android:switchMinWidth="@dimen/theme_switch_min_width"
                                android:text="@null"
                                android:thumb="@drawable/bg_theme_toggle_thumb"
                                android:track="@drawable/bg_theme_toggle_track"
                                app:useMaterialThemeColors="false" />
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <ImageView
                        android:id="@+id/imageThemeIndicator"
                        android:layout_width="@dimen/header_accent_size"
                        android:layout_height="@dimen/header_accent_size"
                        android:layout_marginStart="@dimen/header_accent_margin_start"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_sun" />
                </LinearLayout>
            </LinearLayout>
</LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/sr_outline_soft" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollMainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="@dimen/space_xl"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_screen"
            android:paddingTop="@dimen/home_content_top_padding"
            android:paddingEnd="@dimen/space_screen">

            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/fragmentActiveBookingContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                tools:layout="@layout/fragment_active_booking"
                tools:visibility="visible" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textFindCarTitle"
                    style="@style/TextAppearance.SwiftRent.SectionTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/find_a_car" />

                <TextView
                    android:id="@+id/buttonFavouritesShortcut"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="0dp"
                    android:text="@string/view_all_favourites_default"
                    android:textColor="@color/sr_primary"
                    android:textSize="16sp"
                    android:textStyle="normal" />
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputLayoutSearchCars"
                style="@style/Widget.SwiftRent.SearchField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:hint="@string/search_hint"
                app:startIconDrawable="@android:drawable/ic_menu_search">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editTextSearchCars"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textColor="@color/sr_text_primary"
                    android:textColorHint="@color/sr_text_hint" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:id="@+id/layoutSortFilterRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonSort"
                    style="@style/Widget.SwiftRent.FilterButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sort_button_default" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonFilter"
                    style="@style/Widget.SwiftRent.FilterButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_sm"
                    android:text="@string/filter_button_default" />
            </LinearLayout>

            <TextView
                android:id="@+id/textPositionIndicator"
                style="@style/TextAppearance.SwiftRent.Position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="@dimen/position_indicator_margin_top"
                android:text="@string/sample_position_indicator" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardEmptyCars"
                style="@style/Widget.SwiftRent.SurfaceCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:visibility="gone">

                <TextView
                    android:id="@+id/textEmptyCarsMessage"
                    style="@style/TextAppearance.SwiftRent.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="@dimen/space_xl"
                    android:text="@string/no_cars_match_search" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCurrentCar"
                style="@style/Widget.SwiftRent.CarCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/car_image_height">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="@dimen/space_md"
                            app:cardBackgroundColor="@color/sr_surface"
                            app:cardCornerRadius="@dimen/radius_md"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="@dimen/space_md">

                                <ImageView
                                    android:id="@+id/imageCurrentCar"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:contentDescription="@string/current_car_image"
                                    android:scaleType="fitCenter"
                                    android:src="@drawable/car3_minicooper"
                                    tools:src="@drawable/car3_minicooper" />
                            </FrameLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <ImageButton
                            android:id="@+id/buttonCurrentFavourite"
                            style="@style/Widget.SwiftRent.IconCircleButton"
                            android:layout_gravity="top|end"
                            android:layout_marginTop="@dimen/favourite_overlay_margin_top"
                            android:layout_marginEnd="@dimen/favourite_overlay_margin_end"
                            android:contentDescription="@string/favourite_car"
                            android:src="@drawable/ic_heart_outline" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/sr_card_content_bg"
                        android:orientation="vertical"
                        android:padding="@dimen/car_content_padding">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/textCurrentCarName"
                                style="@style/TextAppearance.SwiftRent.CarTitle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/sample_car_name" />

                            <ImageButton
                                android:id="@+id/buttonCurrentShare"
                                style="@style/Widget.SwiftRent.PlainIconButton"
                                android:layout_width="35dp"
                                android:layout_height="35dp"
                                android:padding="0dp"
                                android:background="@null"
                                android:scaleType="fitCenter"
                                android:contentDescription="@string/share_car"
                                android:src="@android:drawable/ic_menu_share" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/textCurrentCarModelText"
                            style="@style/TextAppearance.SwiftRent.Meta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/car_detail_spacing_sm"
                            android:text="@string/sample_car_model_text"
                            android:textColor="@color/sr_text_primary" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/car_detail_spacing_sm"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/textCurrentRatingValue"
                                style="@style/TextAppearance.SwiftRent.BodyStrong"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/sample_rating_value" />

                            <androidx.appcompat.widget.AppCompatRatingBar
                                android:id="@+id/ratingCurrentCar"
                                style="@style/Widget.AppCompat.RatingBar.Small"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/rating_value_spacing"
                                android:isIndicator="true"
                                android:numStars="5"
                                android:progressBackgroundTint="@color/sr_outline"
                                android:progressTint="@color/sr_star_accent"
                                android:rating="4.2"
                                android:secondaryProgressTint="@color/sr_outline"
                                android:stepSize="0.5" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="@dimen/meta_icon_size"
                                android:layout_height="@dimen/meta_icon_size"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_calendar_small" />

                            <TextView
                                android:id="@+id/textCurrentCarYearText"
                                style="@style/TextAppearance.SwiftRent.Meta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/meta_inline_spacing"
                                android:text="@string/sample_car_year_text" />

                            <ImageView
                                android:layout_width="@dimen/meta_icon_size"
                                android:layout_height="@dimen/meta_icon_size"
                                android:layout_marginStart="@dimen/meta_group_spacing"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_mileage_small" />

                            <TextView
                                android:id="@+id/textCurrentCarMileageText"
                                style="@style/TextAppearance.SwiftRent.Meta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/meta_inline_spacing"
                                android:text="@string/sample_car_mileage_text" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/textCurrentDailyCost"
                            style="@style/TextAppearance.SwiftRent.Price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/car_price_margin_top"
                            android:text="@string/sample_daily_cost" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/layoutPagerButtons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonPreviousCar"
                    style="@style/Widget.SwiftRent.OutlineButtonLarge"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_large_height"
                    android:layout_weight="1"
                    app:icon="@drawable/ic_chevron_left"
                    app:iconGravity="textStart"
                    app:iconPadding="@dimen/space_sm"
                    android:text="@string/previous" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonNextCar"
                    style="@style/Widget.SwiftRent.OutlineButtonLarge"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_large_height"
                    android:layout_marginStart="@dimen/space_md"
                    android:layout_weight="1"
                    app:icon="@drawable/ic_chevron_right"
                    app:iconGravity="textEnd"
                    app:iconPadding="@dimen/space_sm"
                    android:text="@string/next" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonRentCar"
                style="@style/Widget.SwiftRent.PrimaryButtonLarge"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_large_height"
                android:layout_marginTop="@dimen/space_md"
                android:text="@string/rent_this_car" />

            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/fragmentFavouritesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xl"
                tools:layout="@layout/fragment_favourites" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
