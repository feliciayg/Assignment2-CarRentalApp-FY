<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="vertical"
    android:paddingStart="@dimen/dialog_content_horizontal_padding"
    android:paddingTop="@dimen/dialog_content_top_padding"
    android:paddingEnd="@dimen/dialog_content_horizontal_padding"
    android:paddingBottom="@dimen/space_sm">

    <TextView
        android:id="@+id/textRatingHint"
        style="@style/TextAppearance.SwiftRent.Body"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/rating_hint" />

    <androidx.appcompat.widget.AppCompatRatingBar
        android:id="@+id/ratingBarRental"
        style="@android:style/Widget.DeviceDefault.RatingBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/space_sm"
        android:numStars="5"
        android:progressBackgroundTint="@color/sr_outline"
        android:progressTint="@color/sr_star_accent"
        android:stepSize="1"
        android:rating="0"
        android:secondaryProgressTint="@color/sr_outline" />

</LinearLayout>
